pipeline {
    agent any

    environment {
        IMAGE_NAME = "static-web-app"
        CONTAINER_NAME = "static-web-container"
    }

    stages {

        stage('Checkout') {
            steps {
                echo 'Cloning repository...'
                checkout scm
            }
        }

        stage('Validate Files') {
            steps {
                sh '''
                test -f index.html
                test -f style.css
                test -f script.js
                '''
                echo 'Application files found.'
            }
        }

        stage('Build') {
            steps {
                echo 'Static application build completed.'
            }
        }

        stage('Archive Artifacts') {
            steps {
                archiveArtifacts artifacts: '*.html,*.css,*.js', fingerprint: true
            }
        }

        stage('Docker Build') {
            steps {
                sh '''
                docker build -t $IMAGE_NAME .
                '''
            }
        }

        stage('Docker Deploy') {
            steps {
                sh '''
                docker stop $CONTAINER_NAME || true
                docker rm $CONTAINER_NAME || true

                docker run -d \
                  --name $CONTAINER_NAME \
                  -p 80:80 \
                  $IMAGE_NAME
                '''
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully and Docker container deployed!'
        }

        failure {
            echo 'Pipeline failed.'
        }
    }
}